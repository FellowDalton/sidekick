# secrets & logs
nudge.config.json
nudge.log

# host API idempotency store (runtime state, per-vault)
.sidekick-idempotency.json

# web-push subscription store (runtime state, per-vault; never in git)
.sidekick-push.json

# agent runner job store + per-job logs (runtime state, per-vault; never in git)
.sidekick-agent-jobs.json
.sidekick-agent-logs/

# generated copies mirrored into the extension by `sidekick.py regenerate`
chrome-extension/sidekick-data.js
chrome-extension/sidekick-render.js

# atomic-write temp files
*.tmp

# python bytecode
__pycache__/
*.pyc

# Obsidian app state (machine-local)
.obsidian/
