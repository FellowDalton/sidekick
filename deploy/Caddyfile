# Sidekick same-origin router (localhost only).
#
# TLS and public exposure are handled by `tailscale serve` in front of this; Caddy here
# is a plain HTTP router on 127.0.0.1:8080 that does the two things the PWA needs and
# that tailscale serve cannot do on its own:
#   1. strip the /api prefix before proxying to the unprefixed FastAPI routes, and
#   2. SPA fallback (serve index.html for client-side routes) for the static build.
#
# Mirrors web/README.md's prod Caddyfile, minus the public domain / auto-TLS block.
#
# Site label is `:8080` (matches ANY Host) with `bind 127.0.0.1` (listens on loopback only).
# Do NOT use `http://127.0.0.1:8080` here: that makes Caddy match only requests whose Host
# header is `127.0.0.1`, but `tailscale serve` forwards the original Host
# (sidekick.<tailnet>.ts.net) — which would match no site and return an empty 200.

:8080 {
	bind 127.0.0.1
	handle /api/* {
		uri strip_prefix /api
		reverse_proxy 127.0.0.1:8000
	}
	handle {
		root * /srv/sidekick/web/build
		# push-sw.js is importScripts()'d by the generated SW; updateViaCache pins
		# imported scripts through the HTTP cache, so without this a future edit
		# to push-sw.js can lag on devices until they happen to bust the cache.
		header /push-sw.js Cache-Control "no-cache"
		try_files {path} /index.html
		file_server
	}
}
